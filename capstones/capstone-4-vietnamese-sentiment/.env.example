# nlpvi — environment overrides (prefix NLPVI_). Copy to .env and adjust.

NLPVI_LOG_LEVEL=INFO
NLPVI_RANDOM_SEED=13

# model backend: sklearn (default, offline) | phobert (needs .[ml] extras)
NLPVI_MODEL_BACKEND=sklearn
NLPVI_PHOBERT_MODEL_NAME=vinai/phobert-base
NLPVI_MAX_SEQ_LEN=128

# data
NLPVI_DATA_PATH=data/reviews.csv
NLPVI_SYNTHETIC_SIZE=600
NLPVI_TEST_SIZE=0.2

# artifacts
NLPVI_MODEL_DIR=models
NLPVI_MODEL_FILENAME=sentiment.joblib

# mlflow
NLPVI_MLFLOW_ENABLED=true
NLPVI_MLFLOW_TRACKING_URI=file:./mlruns
NLPVI_MLFLOW_EXPERIMENT=nlpvi-sentiment

# serving
NLPVI_API_HOST=0.0.0.0
NLPVI_API_PORT=8000
