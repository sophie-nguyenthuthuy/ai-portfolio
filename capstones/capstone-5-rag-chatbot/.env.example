# Copy to .env and adjust. All vars use the RAGBOT_ prefix (pydantic-settings).
RAGBOT_LOG_LEVEL=INFO
RAGBOT_RANDOM_SEED=42

# corpus / ingestion
RAGBOT_SAMPLE_DOCS_DIR=data/sample_docs
RAGBOT_CHUNK_SIZE=400
RAGBOT_CHUNK_OVERLAP=80

# embeddings: hashing (base dep, default) | sentence-transformers (optional)
RAGBOT_EMBEDDER=hashing
RAGBOT_EMBEDDING_DIM=512
RAGBOT_ST_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# vector store: memory (base dep, default) | qdrant (optional dep)
RAGBOT_VECTOR_STORE=memory
RAGBOT_COLLECTION=sme_docs
RAGBOT_QDRANT_URL=http://localhost:6333

# retrieval
RAGBOT_TOP_K=4
RAGBOT_HYBRID=true
RAGBOT_HYBRID_ALPHA=0.7

# llm: fake (deterministic, default/tests) | ollama
RAGBOT_LLM=fake
RAGBOT_OLLAMA_BASE_URL=http://localhost:11434
RAGBOT_OLLAMA_MODEL=llama3.1
RAGBOT_LLM_TIMEOUT=60.0
RAGBOT_MAX_CONTEXT_CHARS=2000

# api
RAGBOT_API_HOST=0.0.0.0
RAGBOT_API_PORT=8000
