# Copy to .env and adjust. All vars use the MLOPS_ prefix (pydantic-settings).
MLOPS_LOG_LEVEL=INFO
MLOPS_MODEL_NAME=churn-reference

# data
MLOPS_DATA_PATH=data/reference.csv
MLOPS_SYNTHETIC_ROWS=4000
MLOPS_RANDOM_SEED=42
MLOPS_TEST_SIZE=0.2

# model: gradient_boosting | logistic_regression
MLOPS_CLASSIFIER=gradient_boosting

# orchestration: base | prefect
MLOPS_PIPELINE_BACKEND=base
MLOPS_MIN_ROC_AUC=0.7

# registry: local | mlflow
MLOPS_REGISTRY_BACKEND=local
MLOPS_REGISTRY_DIR=registry

# mlflow (optional path)
MLOPS_MLFLOW_TRACKING_URI=./mlruns
MLOPS_MLFLOW_EXPERIMENT=mlops-platform

# monitoring
MLOPS_DRIFT_THRESHOLD=0.25

# api
MLOPS_API_HOST=0.0.0.0
MLOPS_API_PORT=8000
