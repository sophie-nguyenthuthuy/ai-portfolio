# Copy to .env and adjust. All vars use the FORECAST_ prefix.

# --- data ---
FORECAST_DATA_PATH=data/series.csv
FORECAST_DATE_COL=date
FORECAST_VALUE_COL=value
FORECAST_SYNTHETIC_DAYS=730
FORECAST_SEED=42

# --- forecasting ---
FORECAST_SEASON_LENGTH=7
FORECAST_HORIZON=14
FORECAST_TEST_SIZE=28
FORECAST_BACKTEST_FOLDS=3
# baseline | naive_seasonal | sarima | prophet | lstm
FORECAST_MODEL_NAME=baseline
FORECAST_CONF_LEVEL=0.9

# --- artifacts / tracking ---
FORECAST_MODEL_DIR=models
FORECAST_MLFLOW_TRACKING_URI=file:./mlruns
FORECAST_MLFLOW_EXPERIMENT=timeseries-forecast
FORECAST_USE_MLFLOW=true

# --- service ---
FORECAST_APP_NAME=timeseries-forecast
FORECAST_LOG_LEVEL=INFO
