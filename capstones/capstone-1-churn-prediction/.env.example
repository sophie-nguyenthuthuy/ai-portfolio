# Copy to .env and adjust. All vars use the CHURN_ prefix (pydantic-settings).
CHURN_LOG_LEVEL=INFO

# data
CHURN_DATA_PATH=data/telco_churn.csv
CHURN_SYNTHETIC_ROWS=4000
CHURN_RANDOM_SEED=42
CHURN_TEST_SIZE=0.2

# model: gradient_boosting | logistic_regression | xgboost
CHURN_CLASSIFIER=gradient_boosting
CHURN_MODEL_DIR=models
CHURN_MODEL_FILENAME=churn-model.joblib

# mlflow (local file store by default)
CHURN_MLFLOW_TRACKING_URI=./mlruns
CHURN_MLFLOW_EXPERIMENT=churn-prediction

# api
CHURN_API_HOST=0.0.0.0
CHURN_API_PORT=8000
