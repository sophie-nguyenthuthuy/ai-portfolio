# Copy to .env and adjust. All vars are optional (safe defaults in conf/config.yaml).

# data + training
VISION_DATA_PATH=data/documents
VISION_SAMPLES_PER_CLASS=24
VISION_SEED=42
VISION_BACKEND=auto            # auto | torch | dummy
VISION_EPOCHS=3
VISION_IMAGE_SIZE=64

# ocr
VISION_OCR_ENGINE=auto         # auto | pytesseract | easyocr | stub
VISION_OCR_LANG=eng

# artifacts / tracking
VISION_MODEL_DIR=models
VISION_MLFLOW_TRACKING_URI=file:./mlruns
VISION_MLFLOW_EXPERIMENT=cv-invoice-ocr
VISION_USE_MLFLOW=true

# service
VISION_APP_NAME=cv-invoice-ocr
VISION_LOG_LEVEL=INFO
VISION_MAX_UPLOAD_BYTES=8388608
