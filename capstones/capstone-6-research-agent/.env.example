# Copy to .env and adjust. All vars use the AGENT_ prefix (pydantic-settings).
AGENT_LOG_LEVEL=INFO

# agent loop
AGENT_MAX_STEPS=6
# graph backend: auto | langgraph | simple
AGENT_GRAPH_BACKEND=auto

# llm: fake (offline default) | ollama (local server)
AGENT_LLM_BACKEND=fake
AGENT_OLLAMA_BASE_URL=http://localhost:11434
AGENT_OLLAMA_MODEL=llama3.1
AGENT_LLM_TIMEOUT_S=30.0

# tools: search backend fake (offline default) | tavily (needs TAVILY_API_KEY)
AGENT_SEARCH_BACKEND=fake
AGENT_CORPUS_DIR=data/corpus
AGENT_RETRIEVER_TOP_K=3
# TAVILY_API_KEY=

# api
AGENT_API_HOST=0.0.0.0
AGENT_API_PORT=8000
